<Page x:Class="AWAproject.Pages.AddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AWAproject.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddPage" Background="#ffff">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="название" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Row="1" />
        <TextBlock Text="материал" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Row="2" />
        <TextBlock Text="цена" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Row="3" />
        <TextBox x:Name="Txb_Name" Grid.Row="1" Grid.Column="1" />
        <TextBox x:Name="Txb_Material" Grid.Row="2" Grid.Column="1" />
        <TextBox x:Name="Txb_Cost" Grid.Row="3" Grid.Column="1" />
        <Button x:Name="Btn_Add_1" Content="Добавить " Grid.ColumnSpan="2" Grid.Row="4" Height="50" Width="150" Background="#2D6033 " Click="Btn_Add_1_Click"/>
    </Grid>
</Page>
