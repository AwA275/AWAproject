<Page x:Class="AWAproject.Pages.ListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AWAproject.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListPage" Background="#ffff">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Text="Сортировка по цене " Width="150" Height="30"  />
            <ComboBox x:Name="Cmb_Sort_Money"  Width="100" Height="30" SelectionChanged="Cmb_Sort_Money_SelectionChanged" >
            <ComboBoxItem>По Умолчанию</ComboBoxItem>
            <ComboBoxItem>По Возрастанию</ComboBoxItem>
            <ComboBoxItem>По Убыванию</ComboBoxItem>
        </ComboBox>
            <TextBlock Text="Сортировка по Материалу"  Width="150" Height="30"/>
            <ComboBox x:Name="Cmb_Sort_Material" Width="100" Height="30" >
                <ComboBoxItem>Краска</ComboBoxItem>
                <ComboBoxItem>Клей</ComboBoxItem>
                <ComboBoxItem>Дисперсия</ComboBoxItem>
        </ComboBox>
            <TextBlock Text="Поиск" Width="50" Height="30"/>
            <TextBox x:Name="Txb_search" Width="150" Height="30"  />
        <Button x:Name="Btn_search" Content="найти" HorizontalAlignment="Right" VerticalAlignment="Center" Width="100" Height="30" Background="#2D6033"/>
        </StackPanel>
        <ListView x:Name="Listlw" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding Material}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding Cost}"/>
                        </StackPanel>
                        <StackPanel>

                            <TextBlock Text="{Binding Employees}"/>
                        </StackPanel>
                    </StackPanel>

                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="Btn_redact" Content="редактировать" Grid.Row="2"  Height="30 " Width="150" VerticalAlignment="Center" HorizontalAlignment="Right" Background="#2D6033"  Click="Btn_redact_Click" />
        <Button x:Name="Btn_Add" Content="Добавить" Grid.Row="2"  Height="30 " Width="150" VerticalAlignment="Center" HorizontalAlignment="Right" Background="#2D6033" Click="Btn_Add_Click"   />
        </StackPanel>


    </Grid>
</Page>
